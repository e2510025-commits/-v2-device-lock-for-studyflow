# Firebase Admin service account json
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# OAuth client secret for desktop app
GOOGLE_OAUTH_CLIENT_SECRET_PATH=./oauth-client-secret.json
GOOGLE_OAUTH_SCOPES=openid,email,profile

# Firestore location for timer status
# Example: users/{uid}
FIRESTORE_TIMER_DOC_PATH_TEMPLATE=users/{uid}
FIRESTORE_TIMER_FIELD_PATH=status.is_timer_running
FIRESTORE_TIMER_REMAINING_PATH=status.remaining_seconds

# Remote unlock API
REMOTE_UNLOCK_HOST=127.0.0.1
REMOTE_UNLOCK_PORT=8765
REMOTE_UNLOCK_SECRET=change-me
REMOTE_UNLOCK_DURATION_SECONDS=300

# Process check frequency (seconds)
PROCESS_WATCH_INTERVAL_SECONDS=0.5

# Lock behavior: minimize / overlay / both
LOCK_ENFORCEMENT_MODE=both
